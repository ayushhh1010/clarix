# ─── LLM Configuration ────────────────────────────────────────────────────────
# Groq API — used in production (APP_ENV=production)
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Ollama — used in local development (APP_ENV=development, default)
# Install Ollama: https://ollama.com  |  Then: ollama pull llama3.1
OLLAMA_MODEL=llama3.1

# ─── Embedding (HuggingFace, runs locally, no API key needed) ─────────────────
# Model is auto-downloaded on first run (~90MB)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── Google OAuth (keep if using Google Sign-In) ──────────────────────────────

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://copilot:copilot_secret@localhost:5433/copilot_db

# Redis
REDIS_URL=redis://localhost:6380/0

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma

# Cloned repos directory
REPOS_DIR=./data/repos

# Application
APP_ENV=development
LOG_LEVEL=INFO

# Auth / JWT (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=change-me-in-production-use-a-long-random-string
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# GitHub OAuth (https://github.com/settings/developers → New OAuth App)
# Callback URL: http://localhost:8000/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Callback URL: http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
